# Copy to .env when you want real API generation.
# Without these values the app uses the deterministic local fallback.

PORT=8787
LLM_PROVIDER=openai-compatible
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=
# Comma-separated models for the UI dropdown (defaults to LLM_MODEL only — no paid presets)
# LLM_ALLOWED_MODELS=openrouter/owl-alpha

# OpenRouter + Owl Alpha (recommended for agentic workflows):
# LLM_PROVIDER=openai-compatible
# LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=openrouter/owl-alpha
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:5174
# OPENROUTER_APP_TITLE=Research Proposal Agent

# Gemini example:
# LLM_PROVIDER=gemini
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_MODEL=gemini-2.5-flash

# Optional: Semantic Scholar API key (higher rate limits)
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: skip Gemini ranking for literature search (still returns real papers)
# LITERATURE_SKIP_ENRICH=1
