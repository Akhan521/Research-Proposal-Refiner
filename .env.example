# Copy this file to .env and fill in your values.
# Without LLM_API_KEY the app uses a deterministic local fallback.

PORT=8787

# --- Recommended: OpenRouter + Owl Alpha ---
LLM_PROVIDER=openai-compatible
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=sk-or-v1-your_key_here
LLM_MODEL=openrouter/owl-alpha

# Comma-separated models for the UI dropdown (defaults to LLM_MODEL only)
# LLM_ALLOWED_MODELS=openrouter/owl-alpha

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5174
OPENROUTER_APP_TITLE=Research Proposal Agent

# Optional: max tokens per LLM request
# LLM_MAX_TOKENS=16384

# --- Alternative: Google Gemini ---
# LLM_PROVIDER=gemini
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_API_KEY=your_gemini_key
# LLM_MODEL=gemini-2.5-flash

# --- Alternative: OpenAI-compatible endpoint ---
# LLM_PROVIDER=openai-compatible
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=your_key_here
# LLM_MODEL=gpt-4o-mini

# Optional: Semantic Scholar API key (higher rate limits for literature search)
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: skip LLM ranking for literature (still returns real papers)
# LITERATURE_SKIP_ENRICH=1

# Optional: CORS origin for API (default allows local dev)
# CORS_ORIGIN=http://127.0.0.1:5174
