# Copy to .env when you want real API generation.
# Without these values the app uses the deterministic local fallback.

PORT=8787
LLM_PROVIDER=openai-compatible
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=

# Gemini example:
# LLM_PROVIDER=gemini
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_MODEL=gemini-2.5-flash
